{
  "info": {
    "_postman_id": "f6c7f1d4-7c0a-4ee0-9f90-9c5d1e5c2a11",
    "name": "AI Ticket Responder",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for AI Ticket Responder backend (HTTP, streaming, and WebSocket)."
  },
  "variable": [
    { "key": "host", "value": "brudlab.com" },
    { "key": "userId", "value": "U123" },
    { "key": "offerId", "value": "" }
  ],
  "item": [
    {
      "name": "Chat (HTTP streaming) - /chat",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-User-Id", "value": "{{userId}}" },
          { "key": "X-Client-Platform", "value": "android" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"message\": \"I need help with referral.\",\n  \"offer_id\": \"{{offerId}}\"\n}"
        },
        "url": {
          "raw": "https://{{host}}/chat",
          "protocol": "https",
          "host": ["{{host}}"],
          "path": ["chat"]
        },
        "description": "Streams text/plain chunks. End of reply is signaled by the delimiter \"\\n\\n\"."
      },
      "response": []
    },
    {
      "name": "Chat (NDJSON stream) - /v1/chat-stream",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-User-Id", "value": "{{userId}}" },
          { "key": "X-Client-Platform", "value": "android" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"message\": \"I need help with payout.\",\n  \"offer_id\": \"{{offerId}}\"\n}"
        },
        "url": {
          "raw": "https://{{host}}/v1/chat-stream",
          "protocol": "https",
          "host": ["{{host}}"],
          "path": ["v1", "chat-stream"]
        },
        "description": "Streams application/x-ndjson. Each line is a JSON object like {\"delta\":\"...\"}, ending with {\"event\":\"end\"}."
      },
      "response": []
    },
    {
      "name": "Chat (non‑stream) - /v1/chat-sync",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-User-Id", "value": "{{userId}}" },
          { "key": "X-Client-Platform", "value": "android" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"message\": \"When will I be rewarded?\",\n  \"offer_id\": \"{{offerId}}\"\n}"
        },
        "url": {
          "raw": "https://{{host}}/v1/chat-sync",
          "protocol": "https",
          "host": ["{{host}}"],
          "path": ["v1", "chat-sync"]
        },
        "description": "Returns a JSON object with the full answer: { message_id, text, finish_reason }."
      },
      "response": []
    },
    {
      "name": "End Session - /v1/session/end",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-User-Id", "value": "{{userId}}" },
          { "key": "X-Client-Platform", "value": "android" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"reason\": \"user_end\"\n}"
        },
        "url": {
          "raw": "https://{{host}}/v1/session/end",
          "protocol": "https",
          "host": ["{{host}}"],
          "path": ["v1", "session", "end"]
        },
        "description": "Signals session end for non‑WebSocket clients. Returns {\"ok\": true}."
      },
      "response": []
    },
    {
      "name": "WebSocket - /ws (manual frames)",
      "event": [],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Sec-WebSocket-Protocol", "value": "" }
        ],
        "url": {
          "raw": "wss://{{host}}/ws",
          "protocol": "wss",
          "host": ["{{host}}"],
          "path": ["ws"]
        },
        "description": "In Postman, open this request and use the 'Messages' tab to send frames like {\"message\":\"Hello\",\"offer_id\":\"\"} or {\"event\":\"end_chat\"}."
      },
      "response": []
    }
  ]
}
